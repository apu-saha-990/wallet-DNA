# ─── WalletDNA Environment Configuration ───────────────────────────────────────
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ─── API Keys ──────────────────────────────────────────────────────────────────
ETHERSCAN_API_KEY=your_etherscan_api_key_here
TRONSCAN_API_KEY=                          # Optional — public endpoints work without key
DOGECHAIN_API_KEY=                         # Optional — Blockchair free tier

# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=walletdna_secret
DATABASE_URL=postgresql://walletdna:walletdna_secret@localhost:5432/walletdna

# ─── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_PASSWORD=admin                     # Change on first login
PROMETHEUS_PORT=8000

# ─── Alerting ──────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=                       # Optional — paste Discord webhook URL

# ─── App Config ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                             # DEBUG | INFO | WARNING | ERROR
RATE_LIMIT_ETHERSCAN=5                     # requests per second (free tier = 5)
RATE_LIMIT_TRONSCAN=10
RATE_LIMIT_BLOCKCHAIR=30                   # per minute on free tier

# ─── Chain Config ──────────────────────────────────────────────────────────────
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_key   # Optional — for live mempool
